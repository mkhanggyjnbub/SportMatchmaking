@model List<BusinessObjects.MatchPost>

@{
    ViewData["Title"] = "Bài đăng bị report nhiều";
}

<h2 class="admin-page-title mb-1">Bài đăng bị report nhiều</h2>
<p class="admin-page-subtitle mb-3">Danh sách bài đăng có số lượng report cao.</p>

<div class="admin-filter mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>Số report tối thiểu: <strong>@ViewBag.MinReportCount</strong></div>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>CreatorUserId</th>
                    <th>Status</th>
                    <th>CreatedAt</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var post in Model)
                    {
                        <tr>
                            <td>@post.PostId</td>
                            <td class="fw-semibold">@post.Title</td>
                            <td>@post.CreatorUserId</td>
                            <td><span class="badge bg-secondary admin-badge">@post.Status</span></td>
                            <td>@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@post.PostId" class="btn btn-sm btn-info text-white">Chi tiết</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4">Không có bài đăng nào phù hợp.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
