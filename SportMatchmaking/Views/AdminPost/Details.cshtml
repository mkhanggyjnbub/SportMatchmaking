@model BusinessObjects.MatchPost

@{
    ViewData["Title"] = "Chi tiết Bài đăng";

    string GetPostStatusText(byte status)
    {
        return status switch
        {
            1 => "Open",
            2 => "Full",
            3 => "Confirmed",
            4 => "Completed",
            5 => "Cancelled",
            6 => "Expired",
            _ => "Unknown"
        };
    }
}

<h2 class="admin-page-title mb-1">Chi tiết Bài đăng</h2>
<p class="admin-page-subtitle mb-4">Xem đầy đủ nội dung và cập nhật trạng thái bài đăng.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card admin-card mb-4">
    <div class="card-body">
        <dl class="row mb-0 admin-detail-list">
            <dt class="col-sm-3">Post ID</dt>
            <dd class="col-sm-9 fw-semibold">@Model.PostId</dd>

            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">SportId</dt>
            <dd class="col-sm-9">@Model.SportId</dd>

            <dt class="col-sm-3">CreatorUserId</dt>
            <dd class="col-sm-9">@Model.CreatorUserId</dd>

            <dt class="col-sm-3">LocationText</dt>
            <dd class="col-sm-9">@Model.LocationText</dd>

            <dt class="col-sm-3">City</dt>
            <dd class="col-sm-9">@Model.City</dd>

            <dt class="col-sm-3">District</dt>
            <dd class="col-sm-9">@Model.District</dd>

            <dt class="col-sm-3">Google Maps URL</dt>
            <dd class="col-sm-9 text-break">@Model.GoogleMapsUrl</dd>

            <dt class="col-sm-3">StartTime</dt>
            <dd class="col-sm-9">@Model.StartTime.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">EndTime</dt>
            <dd class="col-sm-9">@(Model.EndTime?.ToString("dd/MM/yyyy HH:mm") ?? "")</dd>

            <dt class="col-sm-3">SlotsNeeded</dt>
            <dd class="col-sm-9">@Model.SlotsNeeded</dd>

            <dt class="col-sm-3">Skill Min</dt>
            <dd class="col-sm-9">@Model.SkillMin</dd>

            <dt class="col-sm-3">Skill Max</dt>
            <dd class="col-sm-9">@Model.SkillMax</dd>

            <dt class="col-sm-3">IsUrgent</dt>
            <dd class="col-sm-9">@(Model.IsUrgent ? "Có" : "Không")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary admin-badge">@GetPostStatusText(Model.Status)</span></dd>

            <dt class="col-sm-3">Report Count</dt>
            <dd class="col-sm-9"><span class="badge bg-danger admin-badge">@ViewBag.ReportCount</span></dd>

            <dt class="col-sm-3">CreatedAt</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="card admin-card mb-3">
    <div class="card-body">
        <h5 class="mb-3">Cập nhật trạng thái</h5>
        <form asp-action="UpdateStatus" asp-route-id="@Model.PostId" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()

            <div class="col-md-4">
                <label class="form-label">Status mới</label>
                <select name="status" class="form-select">
                    <option value="1">Open</option>
                    <option value="2">Full</option>
                    <option value="3">Confirmed</option>
                    <option value="4">Completed</option>
                    <option value="5">Cancelled</option>
                    <option value="6">Expired</option>
                </select>
            </div>

            <div class="col-md-4">
                <button type="submit" class="btn btn-primary">Cập nhật trạng thái</button>
            </div>
        </form>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>