@model List<BusinessObjects.MatchPost>

@{
    ViewData["Title"] = "Quản lý Bài đăng";
    var sports = ViewBag.Sports as List<BusinessObjects.Sport>;
    var users = ViewBag.Users as List<BusinessObjects.AppUser>;

    string GetPostStatusText(byte status)
    {
        return status switch
        {
            1 => "Open",
            2 => "Full",
            3 => "Confirmed",
            4 => "Completed",
            5 => "Cancelled",
            6 => "Expired",
            _ => "Unknown"
        };
    }
}

<h2 class="admin-page-title mb-1">Quản lý Bài đăng</h2>
<p class="admin-page-subtitle mb-4">Quản trị bài đăng và trạng thái hoạt động.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" asp-action="Index" class="admin-filter row g-3 mb-4">
    <div class="col-md-3">
        <label class="form-label">Từ khóa</label>
        <input type="text" name="keyword" class="form-control" value="@ViewBag.Keyword" />
    </div>

    <div class="col-md-2">
        <label class="form-label">Sport</label>
        <select name="sportId" class="form-select">
            <option value="">-- Tất cả --</option>
            @if (sports != null)
            {
                foreach (var sport in sports)
                {
                    if (ViewBag.SportId != null && (int)ViewBag.SportId == sport.SportId)
                    {
                        <option value="@sport.SportId" selected>@sport.Name</option>
                    }
                    else
                    {
                        <option value="@sport.SportId">@sport.Name</option>
                    }
                }
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            <option value="">-- Tất cả --</option>
            @if (ViewBag.Status != null && (byte)ViewBag.Status == 1)
            {
                <option value="1" selected>Open</option>
            }
            else
            {
                <option value="1">Open</option>
            }
            @if (ViewBag.Status != null && (byte)ViewBag.Status == 2)
            {
                <option value="2" selected>Full</option>
            }
            else
            {
                <option value="2">Full</option>
            }
            @if (ViewBag.Status != null && (byte)ViewBag.Status == 3)
            {
                <option value="3" selected>Confirmed</option>
            }
            else
            {
                <option value="3">Confirmed</option>
            }
            @if (ViewBag.Status != null && (byte)ViewBag.Status == 4)
            {
                <option value="4" selected>Completed</option>
            }
            else
            {
                <option value="4">Completed</option>
            }
            @if (ViewBag.Status != null && (byte)ViewBag.Status == 5)
            {
                <option value="5" selected>Cancelled</option>
            }
            else
            {
                <option value="5">Cancelled</option>
            }
            @if (ViewBag.Status != null && (byte)ViewBag.Status == 6)
            {
                <option value="6" selected>Expired</option>
            }
            else
            {
                <option value="6">Expired</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label">City</label>
        <input type="text" name="city" class="form-control" value="@ViewBag.City" />
    </div>

    <div class="col-md-3">
        <label class="form-label">District</label>
        <input type="text" name="district" class="form-control" value="@ViewBag.District" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Creator</label>
        <select name="creatorUserId" class="form-select">
            <option value="">-- Tất cả --</option>
            @if (users != null)
            {
                foreach (var user in users)
                {
                    if (ViewBag.CreatorUserId != null && (int)ViewBag.CreatorUserId == user.UserId)
                    {
                        <option value="@user.UserId" selected>@user.UserName</option>
                    }
                    else
                    {
                        <option value="@user.UserId">@user.UserName</option>
                    }
                }
            }
        </select>
    </div>

    <div class="col-md-4 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Lọc</button>
        <a asp-action="HighlyReported" class="btn btn-warning">Bài bị report nhiều</a>
    </div>
</form>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>SportId</th>
                    <th>CreatorUserId</th>
                    <th>City</th>
                    <th>District</th>
                    <th>Status</th>
                    <th>Start Time</th>
                    <th style="width:200px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var post in Model)
                    {
                        <tr>
                            <td>@post.PostId</td>
                            <td class="fw-semibold">@post.Title</td>
                            <td>@post.SportId</td>
                            <td>@post.CreatorUserId</td>
                            <td>@post.City</td>
                            <td>@post.District</td>
                            <td><span class="badge bg-secondary admin-badge">@GetPostStatusText(post.Status)</span></td>
                            <td>@post.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="admin-actions">
                                <a asp-action="Details" asp-route-id="@post.PostId" class="btn btn-sm btn-info text-white">Chi tiết</a>

                                <form asp-action="Cancel" asp-route-id="@post.PostId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Bạn có chắc muốn hủy bài đăng này?')">
                                        Hủy bài
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-4">Không có dữ liệu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
