@model SportMatchmaking.Models.AdminPostStatisticsVM
@using System.Text.Json

@{
    ViewData["Title"] = "Thong ke bai dang";
}

<h2 class="admin-page-title mb-1">Th&#7889;ng k&#234; b&#224;i &#273;&#259;ng</h2>
<p class="admin-page-subtitle mb-4">Ph&#226;n t&#237;ch s&#7889; l&#432;&#7907;ng b&#224;i &#273;&#259;ng theo m&#244;n, tr&#7841;ng th&#225;i v&#224; tu&#7847;n trong n&#259;m.</p>

<div class="admin-filter row g-3 mb-4">
    <div class="col-md-6">
        <div class="small text-muted">T&#7893;ng s&#7889; m&#244;n th&#7875; thao</div>
        <div class="fs-4 fw-bold">@Model.TotalSports</div>
    </div>
    <div class="col-md-6">
        <div class="small text-muted">T&#7893;ng s&#7889; b&#224;i &#273;&#259;ng</div>
        <div class="fs-4 fw-bold">@Model.TotalPosts</div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card admin-card h-100">
            <div class="card-body">
                <h5 class="mb-3">1) T&#7927; l&#7879; b&#224;i &#273;&#259;ng theo m&#244;n th&#7875; thao</h5>
                <canvas id="sportSharePie"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card admin-card h-100">
            <div class="card-body">
                <h5 class="mb-3">2) S&#7889; b&#224;i Open/Full theo m&#244;n th&#7875; thao</h5>
                <div class="admin-chart-scroll-x">
                    <div class="admin-chart-wide" id="openFullBarWrap">
                        <canvas id="sportOpenFullBar"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card admin-card h-100">
            <div class="card-body">
                <h5 class="mb-3">3) T&#7927; l&#7879; b&#224;i &#273;&#259;ng theo tr&#7841;ng th&#225;i</h5>
                <canvas id="statusSharePie"></canvas>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card admin-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-end gap-2 flex-wrap">
                    <h5 class="mb-0">4) S&#7889; l&#432;&#7907;ng b&#224;i &#273;&#259;ng theo tu&#7847;n trong n&#259;m @Model.SelectedYear</h5>
                    <form method="get" asp-action="Statistics" class="admin-weekly-filter">
                        <div>
                            <label class="form-label mb-1">N&#259;m</label>
                            <select name="year" class="form-select form-select-sm">
                                @foreach (var y in Model.AvailableYears)
                                {
                                    if (y == Model.SelectedYear)
                                    {
                                        <option value="@y" selected>@y</option>
                                    }
                                    else
                                    {
                                        <option value="@y">@y</option>
                                    }
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Xem</button>
                    </form>
                </div>

                <div class="admin-chart-scroll-x mt-3">
                    <div class="admin-chart-wide">
                        <canvas id="weeklyPostsBar"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Quay l&#7841;i qu&#7843;n l&#253; b&#224;i &#273;&#259;ng</a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const sportLabels = @Html.Raw(JsonSerializer.Serialize(Model.SportLabels));
        const sportCounts = @Html.Raw(JsonSerializer.Serialize(Model.SportCounts));

        const openFullLabels = @Html.Raw(JsonSerializer.Serialize(Model.OpenOrFullSportLabels));
        const openFullCounts = @Html.Raw(JsonSerializer.Serialize(Model.OpenOrFullSportCounts));

        const weekLabels = @Html.Raw(JsonSerializer.Serialize(Model.WeekLabels));
        const weeklyCounts = @Html.Raw(JsonSerializer.Serialize(Model.WeeklyPostCounts));

        const statusLabels = @Html.Raw(JsonSerializer.Serialize(Model.StatusLabels));
        const statusCounts = @Html.Raw(JsonSerializer.Serialize(Model.StatusCounts));

        const palette = [
            '#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4', '#84cc16', '#f97316', '#ec4899', '#14b8a6'
        ];

        const totalSportPosts = sportCounts.reduce((a, b) => a + b, 0);
        new Chart(document.getElementById('sportSharePie'), {
            type: 'pie',
            data: {
                labels: sportLabels,
                datasets: [{
                    data: sportCounts,
                    backgroundColor: sportLabels.map((_, i) => palette[i % palette.length])
                }]
            },
            options: {
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: (ctx) => {
                                const value = ctx.raw || 0;
                                const pct = totalSportPosts > 0 ? (value * 100 / totalSportPosts).toFixed(1) : 0;
                                return `${ctx.label}: ${value} bai (${pct}%)`;
                            }
                        }
                    }
                }
            }
        });

        const maxOpenFull = Math.max(...openFullCounts, 0);
        const isOpenFullRatioScale = maxOpenFull <= 1;
        const openFullCanvas = document.getElementById('sportOpenFullBar');
        const openFullWrap = document.getElementById('openFullBarWrap');
        const openFullChartWidth = Math.max(openFullWrap.clientWidth, openFullLabels.length * 68);
        openFullCanvas.style.width = `${openFullChartWidth}px`;
        openFullCanvas.style.height = '280px';

        new Chart(openFullCanvas, {
            type: 'bar',
            data: {
                labels: openFullLabels,
                datasets: [{
                    label: 'So bai Open/Full',
                    data: openFullCounts,
                    backgroundColor: '#3b82f6'
                }]
            },
            options: {
                responsive: false,
                maintainAspectRatio: false,
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: (ctx) => {
                                const value = Number(ctx.raw || 0);
                                if (isOpenFullRatioScale) {
                                    return `${ctx.dataset.label}: ${(value * 100).toFixed(0)}%`;
                                }

                                return `${ctx.dataset.label}: ${value}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: { maxRotation: 0, autoSkip: true, maxTicksLimit: 12 }
                    },
                    y: {
                        beginAtZero: true,
                        suggestedMax: maxOpenFull,
                        ticks: {
                            precision: isOpenFullRatioScale ? undefined : 0,
                            callback: (value) => isOpenFullRatioScale ? `${Math.round(Number(value) * 100)}%` : value
                        }
                    }
                }
            }
        });

        const weeklyCanvas = document.getElementById('weeklyPostsBar');
        const chartWidth = Math.max(960, weekLabels.length * 32);
        weeklyCanvas.style.width = `${chartWidth}px`;
        weeklyCanvas.style.height = '320px';

        new Chart(weeklyCanvas, {
            type: 'bar',
            data: {
                labels: weekLabels.map(w => `Tuan ${w}`),
                datasets: [{
                    label: 'So bai dang',
                    data: weeklyCounts,
                    backgroundColor: '#22c55e'
                }]
            },
            options: {
                responsive: false,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        ticks: { maxRotation: 0, autoSkip: true, maxTicksLimit: 20 }
                    },
                    y: { beginAtZero: true }
                }
            }
        });

        const totalByStatus = statusCounts.reduce((a, b) => a + b, 0);
        new Chart(document.getElementById('statusSharePie'), {
            type: 'pie',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusCounts,
                    backgroundColor: statusLabels.map((_, i) => palette[i % palette.length])
                }]
            },
            options: {
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: (ctx) => {
                                const value = ctx.raw || 0;
                                const pct = totalByStatus > 0 ? (value * 100 / totalByStatus).toFixed(1) : 0;
                                return `${ctx.label}: ${value} bai (${pct}%)`;
                            }
                        }
                    }
                }
            }
        });
    </script>
}
