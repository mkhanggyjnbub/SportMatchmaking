@using Repositories.AppUser
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportMatchmaking</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/register.css" />
    <link rel="stylesheet" href="~/SportMatchmaking.styles.css" asp-append-version="true" />
</head>
<body class="@(Context.Session.GetString("RoleName") == "Admin" ? "admin-sidebar-enabled" : "")">
    @{
        var userId = Context.Session.GetInt32("UserId");
        var avatarUrl = Context.Session.GetString("AvatarUrl") ?? "/images/default-avatar.png";
        var displayName = Context.Session.GetString("DisplayName") ?? "Account";
        var roleName = Context.Session.GetString("RoleName");
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var isAdmin = roleName == "Admin";
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">SportMatchmaking</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @* <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul> *@


                    @* xử lí profile *@

                    <ul class="navbar-nav ms-auto">
                        @if (Context.Session.GetString("UserName") == null)
                        {
                            <!-- Guest -->
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Register">Register</a>
                            </li>
                        }
                        @if (userId != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                                   href="#"
                                   id="profileDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <img src="@avatarUrl"
                                         alt="Avatar"
                                         class="rounded-circle border"
                                         style="width:40px;height:40px;object-fit:cover;" />
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                    <li>
                                        <a class="dropdown-item" href="javascript:void(0)" onclick="openProfileModal()">
                                            View Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="javascript:void(0)" onclick="openEditProfileModal()">
                                            Update Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="javascript:void(0)" onclick="openChangePasswordModal()">
                                            Change Password
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                            Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>



                    @* Xử lí logout *@
                    @* <ul class="navbar-nav ms-auto">
                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>
                        }
                    </ul> *@


                </div>
            </div>
        </nav>
    </header>

    @if (isAdmin)
    {
        <aside id="adminSidebar" class="admin-sidebar">
            <div class="admin-sidebar-header">
                <button type="button" id="adminSidebarToggle" class="btn btn-link text-white admin-sidebar-toggle" aria-label="Toggle admin sidebar">
                    ☰
                </button>
                <div class="admin-sidebar-title">Admin Menu</div>
            </div>
            <nav class="admin-sidebar-nav">
                <a asp-controller="AdminDashboard" asp-action="Index" class="admin-sidebar-link @((currentController == "AdminDashboard") ? "active" : "")">
                    <span class="admin-sidebar-icon">🏠</span>
                    <span class="admin-sidebar-label">Dashboard</span>
                </a>
                <a asp-controller="AdminUser" asp-action="Index" class="admin-sidebar-link @((currentController == "AdminUser") ? "active" : "")">
                    <span class="admin-sidebar-icon">👤</span>
                    <span class="admin-sidebar-label">Quản lý User</span>
                </a>
                <a asp-controller="AdminSport" asp-action="Index" class="admin-sidebar-link @((currentController == "AdminSport" && (currentAction == "Index" || currentAction == "Details" || currentAction == "Create" || currentAction == "Edit")) ? "active" : "")">
                    <span class="admin-sidebar-icon">🏅</span>
                    <span class="admin-sidebar-label">Quản lý Sport</span>
                </a>
                <a asp-controller="AdminSport" asp-action="Images" class="admin-sidebar-link @((currentController == "AdminSport" && (currentAction == "Images" || currentAction == "CreateImage" || currentAction == "EditImage")) ? "active" : "")">
                    <span class="admin-sidebar-icon">🖼️</span>
                    <span class="admin-sidebar-label">Quản lý Image</span>
                </a>
                <a asp-controller="AdminPost" asp-action="Index" class="admin-sidebar-link @((currentController == "AdminPost" && currentAction != "Statistics") ? "active" : "")">
                    <span class="admin-sidebar-icon">📝</span>
                    <span class="admin-sidebar-label">Quản lý Bài đăng</span>
                </a>
                <a asp-controller="AdminPost" asp-action="Statistics" class="admin-sidebar-link @((currentController == "AdminPost" && currentAction == "Statistics") ? "active" : "")">
                    <span class="admin-sidebar-icon">📊</span>
                    <span class="admin-sidebar-label">Thống kê Bài đăng</span>
                </a>
                <a asp-controller="AdminReport" asp-action="Index" class="admin-sidebar-link @((currentController == "AdminReport") ? "active" : "")">
                    <span class="admin-sidebar-icon">🚩</span>
                    <span class="admin-sidebar-label">Quản lý Report</span>
                </a>
            </nav>
        </aside>
    }

    <div class="container app-main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>



    <div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" id="profileModalContent">
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container app-footer-container">
            &copy; 2026 - SportMatchmaking - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        const adminSidebarToggle = document.getElementById('adminSidebarToggle');

        if (adminSidebarToggle) {
            adminSidebarToggle.addEventListener('click', function () {
                document.body.classList.toggle('admin-sidebar-collapsed');
            });
        }

        function openProfileModal() {
            fetch('/Profile/GetProfilePartial')
                .then(response => response.text())
                .then(html => {
                    document.getElementById('profileModalContent').innerHTML = html;
                    const modal = new bootstrap.Modal(document.getElementById('profileModal'));
                    modal.show();
                });
        }

        function openEditProfileModal() {
            fetch('/Profile/GetEditProfilePartial')
                .then(response => response.text())
                .then(html => {
                    document.getElementById('profileModalContent').innerHTML = html;
                    const modal = new bootstrap.Modal(document.getElementById('profileModal'));
                    modal.show();

                    bindEditProfileForm();
                });
        }

        function bindEditProfileForm() {
            const form = document.getElementById('editProfileForm');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                const formData = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                .then(async response => {
                    const contentType = response.headers.get("content-type");

                    if (contentType && contentType.includes("application/json")) {
                        const result = await response.json();
                        if (result.success) {
                            location.reload();
                        }
                    } else {
                        const html = await response.text();
                        document.getElementById('profileModalContent').innerHTML = html;
                        bindEditProfileForm();
                    }
                });
            });
        }

        function openChangePasswordModal() {
            fetch('/Profile/GetChangePasswordPartial')
                .then(response => response.text())
                .then(html => {
                    document.getElementById('profileModalContent').innerHTML = html;
                    const modal = new bootstrap.Modal(document.getElementById('profileModal'));
                    modal.show();
                    bindChangePasswordForm();
                });
        }

        function bindEditProfileForm() {
            const form = document.getElementById('editProfileForm');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                const formData = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                .then(async response => {
                    const contentType = response.headers.get("content-type");

                    if (contentType && contentType.includes("application/json")) {
                        const result = await response.json();
                        if (result.success) {
                            location.reload();
                        }
                    } else {
                        const html = await response.text();
                        document.getElementById('profileModalContent').innerHTML = html;
                        bindEditProfileForm();
                    }
                });
            });
        }

        function bindChangePasswordForm() {
            const form = document.getElementById('changePasswordForm');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                const formData = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                .then(async response => {
                    const contentType = response.headers.get("content-type");

                    if (contentType && contentType.includes("application/json")) {
                        const result = await response.json();
                        if (result.success) {
                            alert(result.message);
                            const modalEl = document.getElementById('profileModal');
                            const modal = bootstrap.Modal.getInstance(modalEl);
                            modal.hide();
                        }
                    } else {
                        const html = await response.text();
                        document.getElementById('profileModalContent').innerHTML = html;
                        bindChangePasswordForm();
                    }
                });
            });
        }
    </script>
</body>
</html>
