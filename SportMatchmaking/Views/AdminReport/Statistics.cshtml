@model Dictionary<byte, int>

@{
    ViewData["Title"] = "Thống kê lý do Report";
}

<h2 class="admin-page-title mb-1">Thống kê lý do Report</h2>
<p class="admin-page-subtitle mb-4">Tổng hợp số lượng report theo từng reason code.</p>

<div class="admin-filter mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>Tổng số mã lý do: <strong>@(Model?.Count ?? 0)</strong></div>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table table-hover mb-0 admin-table admin-table-mobile-cards">
            <thead>
                <tr>
                    <th>Reason Code</th>
                    <th>Số lượng</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Reason Code">@item.Key</td>
                            <td data-label="Số lượng"><span class="badge bg-primary admin-badge">@item.Value</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center py-4">Không có dữ liệu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
