@model BusinessObjects.Report

@{
    ViewData["Title"] = "Chi tiết Report";

    string GetReportStatusText(byte status)
    {
        return status switch
        {
            1 => "Open",
            2 => "In Review",
            3 => "Resolved",
            4 => "Dismissed",
            _ => "Unknown"
        };
    }

    string GetTargetTypeText(byte targetType)
    {
        return targetType switch
        {
            1 => "Post",
            2 => "User",
            _ => "Unknown"
        };
    }
}

<h2 class="admin-page-title mb-1">Chi tiết Report</h2>
<p class="admin-page-subtitle mb-4">Xử lý trạng thái và theo dõi nội dung report.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card admin-card mb-4">
    <div class="card-body">
        <dl class="row mb-0 admin-detail-list">
            <dt class="col-sm-3">ReportId</dt>
            <dd class="col-sm-9 fw-semibold">@Model.ReportId</dd>

            <dt class="col-sm-3">ReporterUserId</dt>
            <dd class="col-sm-9">@Model.ReporterUserId</dd>

            <dt class="col-sm-3">TargetType</dt>
            <dd class="col-sm-9">@GetTargetTypeText(Model.TargetType)</dd>

            <dt class="col-sm-3">TargetPostId</dt>
            <dd class="col-sm-9">@Model.TargetPostId</dd>

            <dt class="col-sm-3">TargetUserId</dt>
            <dd class="col-sm-9">@Model.TargetUserId</dd>

            <dt class="col-sm-3">ReasonCode</dt>
            <dd class="col-sm-9">@Model.ReasonCode</dd>

            <dt class="col-sm-3">Details</dt>
            <dd class="col-sm-9">@Model.Details</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary admin-badge">@GetReportStatusText(Model.Status)</span></dd>

            <dt class="col-sm-3">ReviewedByUserId</dt>
            <dd class="col-sm-9">@Model.ReviewedByUserId</dd>

            <dt class="col-sm-3">ReviewedAt</dt>
            <dd class="col-sm-9">@(Model.ReviewedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</dd>

            <dt class="col-sm-3">Resolution</dt>
            <dd class="col-sm-9">@Model.Resolution</dd>

            <dt class="col-sm-3">CreatedAt</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card admin-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Resolve Report</h6>
                <form asp-action="Resolve" asp-route-id="@Model.ReportId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">Nội dung xử lý</label>
                        <textarea name="resolution" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-success">Resolve</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card admin-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Dismiss Report</h6>
                <form asp-action="Dismiss" asp-route-id="@Model.ReportId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">Lý do từ chối</label>
                        <textarea name="resolution" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger">Dismiss</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>
