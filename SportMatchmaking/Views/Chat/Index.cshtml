@model Services.Models.Chat.ChatIndexViewModel

@{
    ViewData["Title"] = "Kênh chat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .chat-shell {
            margin-top: 1rem;
            margin-bottom: 1.5rem;
        }

        .chat-page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

            .chat-page-header h1 {
                margin-bottom: 0.25rem;
                font-size: 2.3rem;
                font-weight: 700;
                color: #1f2937;
            }

            .chat-page-header p {
                margin: 0;
                color: #6b7280;
                font-size: 1.05rem;
            }

        .chat-page {
            display: grid;
            grid-template-columns: 290px 1fr;
            height: calc(100vh - 250px);
            min-height: 520px;
            max-height: 620px;
            border-radius: 20px;
            overflow: hidden;
            background: #fff;
            border: 1px solid #dbe4f0;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        }

        .sidebar {
            border-right: 1px solid #dbe4f0;
            background: #fff;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .sidebar-header {
            padding: 18px 16px 14px;
            background: linear-gradient(135deg, #1d4ed8, #2563eb);
            color: #fff;
        }

            .sidebar-header h2 {
                font-size: 1.1rem;
                font-weight: 700;
                margin-bottom: 0.25rem;
            }

            .sidebar-header p {
                margin: 0;
                opacity: 0.92;
                font-size: 0.9rem;
            }

        .search-box {
            padding: 12px 14px 10px;
            border-bottom: 1px solid #e5edf8;
            background: #fff;
        }

            .search-box input {
                width: 100%;
                border: 1px solid #cfd9e8;
                border-radius: 12px;
                padding: 10px 12px;
                font-size: 0.95rem;
                outline: none;
            }

                .search-box input:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
                }

        .room-list {
            overflow-y: auto;
            flex: 1;
            min-height: 0;
            background: #fff;
        }

        .room-item {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            padding: 14px;
            text-decoration: none;
            color: inherit;
            border-left: 4px solid transparent;
            transition: background 0.2s ease;
        }

            .room-item:hover {
                background: #f8fbff;
                text-decoration: none;
                color: inherit;
            }

            .room-item.active {
                background: #eaf3ff;
                border-left-color: #2563eb;
            }

        .avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: #22c55e;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
            flex-shrink: 0;
            text-transform: uppercase;
        }

        .room-content {
            flex: 1;
            min-width: 0;
        }

        .room-top {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            align-items: flex-start;
        }

        .room-name-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            min-width: 0;
        }

        .room-name {
            font-size: 1rem;
            font-weight: 700;
            color: #1e3a8a;
            margin-bottom: 0.15rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .room-unread-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ef4444;
            flex-shrink: 0;
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
        }

        .room-unread-dot.hidden {
            display: none;
        }

        .room-time {
            color: #64748b;
            font-size: 0.75rem;
            white-space: nowrap;
        }

        .room-last-message {
            color: #475569;
            margin-bottom: 0.15rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 0.85rem;
        }

        .room-meta {
            color: #64748b;
            font-size: 0.8rem;
        }

        .empty-sidebar {
            padding: 1.25rem;
            color: #64748b;
            text-align: center;
        }

        .chat-main {
            display: flex;
            flex-direction: column;
            min-width: 0;
            min-height: 0;
            height: 100%;
            overflow: hidden;
            background: #fff;
        }

        .chat-header {
            padding: 12px 16px;
            border-bottom: 1px solid #dbe4f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            background: #fff;
            flex: 0 0 auto;
        }

        .chat-header-left {
            display: flex;
            gap: 12px;
            align-items: center;
            min-width: 0;
        }

        .chat-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #2563eb;
            margin-bottom: 0.1rem;
        }

        .chat-subtitle {
            color: #64748b;
            font-size: 0.9rem;
        }

        .status-badge {
            background: #dcfce7;
            color: #15803d;
            padding: 8px 14px;
            border-radius: 999px;
            font-weight: 600;
            white-space: nowrap;
            font-size: 0.85rem;
        }

        .messages {
            flex: 1 1 auto;
            min-height: 0;
            overflow-y: auto;
            padding: 14px 16px;
            background: #f8fbff;
            border-bottom: 1px solid #dbe4f0;
        }

        .empty-messages {
            display: flex;
            justify-content: center;
            align-items: center;
            color: #64748b;
            min-height: 100%;
            text-align: center;
        }

        .date-divider {
            text-align: center;
            color: #64748b;
            margin-bottom: 14px;
            font-size: 0.9rem;
        }

        .message-row {
            display: flex;
            margin-bottom: 14px;
        }

            .message-row.right {
                justify-content: flex-end;
            }

            .message-row.left {
                justify-content: flex-start;
            }

        .message-bubble {
            max-width: 260px;
            border-radius: 18px;
            padding: 10px 12px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
        }

        .message-row.right .message-bubble {
            background: #1d4ed8;
            color: #fff;
        }

        .message-row.left .message-bubble {
            background: #fff;
            border: 1px solid #dbe4f0;
            color: #0f172a;
        }

        .sender-name {
            font-weight: 700;
            margin-bottom: 4px;
            color: #16a34a;
            font-size: 0.82rem;
        }

        .message-text {
            font-size: 1rem;
            line-height: 1.4;
            word-break: break-word;
        }

        .deleted-message {
            font-style: italic;
            opacity: 0.8;
        }

        .edited-text {
            font-style: italic;
            opacity: 0.75;
            margin-top: 4px;
            font-size: 0.85rem;
        }

        .message-time {
            margin-top: 6px;
            font-size: 0.78rem;
            opacity: 0.8;
        }

        .message-actions {
            margin-top: 6px;
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }

        .message-action-btn {
            border: none;
            background: none;
            padding: 0;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            font-size: 0.9rem;
        }

        .edit-btn {
            color: #facc15;
        }

        .delete-btn {
            color: #fb923c;
        }

        .input-area {
            flex: 0 0 auto;
            padding: 12px 16px;
            background: #fff;
            display: flex;
            gap: 10px;
            align-items: center;
            border-top: 1px solid #e5edf8;
        }

            .input-area input[type="text"] {
                flex: 1;
                border: 1px solid #cfd9e8;
                border-radius: 14px;
                padding: 10px 14px;
                font-size: 0.95rem;
                outline: none;
            }

                .input-area input[type="text"]:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
                }

        .send-btn {
            border: none;
            background: #22c55e;
            color: #fff;
            font-weight: 700;
            padding: 10px 20px;
            border-radius: 14px;
            font-size: 0.9rem;
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.45);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1050;
        }

            .modal-overlay.show {
                display: flex;
            }

        .edit-modal {
            width: 100%;
            max-width: 520px;
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.2);
        }

        .edit-modal-header {
            padding: 18px 22px;
            font-weight: 700;
            border-bottom: 1px solid #e5edf8;
        }

        .edit-modal-body {
            padding: 20px 22px;
        }

            .edit-modal-body textarea {
                width: 100%;
                min-height: 120px;
                border: 1px solid #cfd9e8;
                border-radius: 12px;
                padding: 12px 14px;
                outline: none;
                resize: vertical;
            }

        .edit-modal-footer {
            padding: 16px 22px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            border-top: 1px solid #e5edf8;
        }

        .modal-btn {
            border: none;
            border-radius: 10px;
            padding: 10px 16px;
            font-weight: 600;
        }

        .modal-btn-cancel {
            background: #e5e7eb;
            color: #111827;
        }

        .modal-btn-save {
            background: #2563eb;
            color: #fff;
        }

        @@media (max-width: 991.98px) {
            .chat-page {
                grid-template-columns: 1fr;
                height: auto;
                max-height: none;
            }

            .messages {
                min-height: 360px;
                max-height: 360px;
            }
        }
    </style>
}

<div class="container py-3 mb-4 chat-shell">
    <div class="chat-page-header">
        <div>
            <h1>Kênh chat</h1>
            <p>Trao đổi với các thành viên trong bài đăng bạn đang tham gia.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="MatchPost"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                Quay lại feed
            </a>
        </div>
    </div>

    <div class="chat-page">
        <div class="sidebar">
            <div class="sidebar-header">
                <h2>Sport Chat</h2>
                <p>Danh sách phòng bạn đang tham gia</p>
            </div>

            <div class="search-box">
                <input type="text" id="chatRoomSearch" placeholder="Tìm phòng chat..." />
            </div>

            <div class="room-list" id="chatRoomList">
                @if (Model.Rooms != null && Model.Rooms.Any())
                {
                    foreach (var room in Model.Rooms)
                    {
                        var avatarText = !string.IsNullOrWhiteSpace(room.RoomName)
                        ? room.RoomName.Trim()[0].ToString().ToUpper()
                        : "#";

                        <a href="/MatchPost/Chat?threadId=@room.ThreadId"
                               class="room-item @(room.IsSelected ? "active" : "")"
                               data-thread-id="@room.ThreadId"
                               data-room-name="@room.RoomName.ToLowerInvariant()"
                               data-room-message="@room.LastMessage.ToLowerInvariant()">
                            <div class="avatar">@avatarText</div>

                            <div class="room-content">
                                <div class="room-top">
                                    <div class="room-name-wrap">
                                        <div class="room-name">@room.RoomName</div>
                                        <span class="room-unread-dot @(room.HasUnread ? "" : "hidden")"
                                              data-unread-dot-for="@room.ThreadId"></span>
                                    </div>
                                    <div class="room-time">@room.LastMessageTimeText</div>
                                </div>

                                <div class="room-last-message">@room.LastMessage</div>
                                <div class="room-meta">@room.MemberCount thành viên</div>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="empty-sidebar">
                        Bạn chưa tham gia phòng chat nào.
                    </div>
                }
            </div>
        </div>

        <div class="chat-main">
            <div class="chat-header">
                <div class="chat-header-left">
                    <div class="avatar">
                        @{
                            var selectedAvatar = !string.IsNullOrWhiteSpace(Model.SelectedRoomTitle)
                            ? Model.SelectedRoomTitle.Trim()[0].ToString().ToUpper()
                            : "-";
                        }
                        @selectedAvatar
                    </div>

                    <div>
                        <div class="chat-title">@Model.SelectedRoomTitle</div>
                        <div class="chat-subtitle">@Model.SelectedRoomSubtitle</div>
                    </div>
                </div>

                <div class="status-badge">
                    @(Model.SelectedRoomMemberCount > 0 ? $"{Model.SelectedRoomMemberCount} thành viên" : "Chưa chọn phòng")
                </div>
            </div>

            <div class="messages" id="chatMessages">
                @if (Model.SelectedThreadId.HasValue && Model.Messages != null && Model.Messages.Any())
                {
                    <div class="date-divider">Tin nhắn</div>

                    @foreach (var msg in Model.Messages)
                    {
                        <div class="message-row @(msg.IsMine ? "right" : "left")">
                            <div class="message-bubble">
                                @if (!msg.IsMine)
                                {
                                    <div class="sender-name">@msg.SenderName</div>
                                }

                                <div class="message-text @(msg.IsDeleted ? "deleted-message" : "")">
                                    @msg.MessageText
                                </div>

                                @if (msg.EditedAt.HasValue && !msg.IsDeleted)
                                {
                                    <div class="edited-text">(đã chỉnh sửa)</div>
                                }

                                <div class="message-time">@msg.SentAt.ToLocalTime().ToString("dd/MM HH:mm")</div>

                                @if (msg.CanEditOrDelete)
                                {
                                    <div class="message-actions">
                                        <button type="button"
                                                class="message-action-btn edit-btn js-edit-message"
                                                data-message-id="@msg.MessageId"
                                                data-message-text="@msg.MessageText">
                                            Sửa
                                        </button>

                                        <form action="/MatchPost/Chat/delete"
                                              method="post"
                                              style="display:inline;">
                                            <input type="hidden" name="messageId" value="@msg.MessageId" />
                                            <input type="hidden" name="threadId" value="@msg.ThreadId" />
                                            <button type="submit" class="message-action-btn delete-btn">
                                                Xóa
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-messages">
                        <div>
                            <div style="font-size: 1.2rem; font-weight: 600; margin-bottom: 0.4rem;">
                                @Model.SelectedRoomTitle
                            </div>
                            <div>@Model.SelectedRoomSubtitle</div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.SelectedThreadId.HasValue)
            {
                <form action="/MatchPost/Chat/send"
                      method="post"
                      class="input-area">
                    <input type="hidden" name="threadId" value="@Model.SelectedThreadId" />
                    <input type="text" name="messageText" placeholder="Nhập tin nhắn..." autocomplete="off" />
                    <button type="submit" class="send-btn">Gửi</button>
                </form>
            }
        </div>
    </div>
</div>

<div id="editModalOverlay" class="modal-overlay">
    <div class="edit-modal">
        <div class="edit-modal-header">
            Sửa tin nhắn
        </div>

        <form action="/MatchPost/Chat/edit"
              method="post"
              id="editMessageForm">
            <div class="edit-modal-body">
                <input type="hidden" name="messageId" id="editMessageId" />
                <input type="hidden" name="threadId" value="@Model.SelectedThreadId" />

                <textarea name="newText"
                          id="editMessageText"
                          placeholder="Nhập nội dung mới..."></textarea>
            </div>

            <div class="edit-modal-footer">
                <button type="button"
                        class="modal-btn modal-btn-cancel"
                        onclick="closeEditModal()">
                    Hủy
                </button>

                <button type="submit"
                        class="modal-btn modal-btn-save">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script>
        function openEditModal(messageId, currentText) {
            const overlay = document.getElementById('editModalOverlay');
            const idInput = document.getElementById('editMessageId');
            const textInput = document.getElementById('editMessageText');

            if (!overlay || !idInput || !textInput) return;

            idInput.value = messageId;
            textInput.value = currentText || '';
            overlay.classList.add('show');
            textInput.focus();
        }

        function closeEditModal() {
            const overlay = document.getElementById('editModalOverlay');
            if (overlay) {
                overlay.classList.remove('show');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.js-edit-message').forEach(button => {
                button.addEventListener('click', function () {
                    const messageId = this.dataset.messageId;
                    const messageText = this.dataset.messageText || '';
                    openEditModal(messageId, messageText);
                });
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeEditModal();
                }
            });

            document.getElementById('editModalOverlay')?.addEventListener('click', function (event) {
                if (event.target === this) {
                    closeEditModal();
                }
            });

            const chatMessages = document.getElementById('chatMessages');
            if (chatMessages) {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            const searchInput = document.getElementById('chatRoomSearch');
            const roomList = document.getElementById('chatRoomList');

            if (searchInput && roomList) {
                searchInput.addEventListener('input', function () {
                    const keyword = this.value.trim().toLowerCase();
                    const items = roomList.querySelectorAll('.room-item');

                    items.forEach(item => {
                        const roomName = item.getAttribute('data-room-name') || '';
                        const roomMessage = item.getAttribute('data-room-message') || '';
                        const matched = roomName.includes(keyword) || roomMessage.includes(keyword);

                        item.style.display = matched ? 'flex' : 'none';
                    });
                });
            }

            const selectedThreadId = '@(Model.SelectedThreadId?.ToString() ?? "")';
            const currentUserId = '@Model.CurrentUserId';
            const currentUserGroup = currentUserId ? `user-${currentUserId}` : '';
            const unreadStorageKey = currentUserId ? `chat-unread:${currentUserId}` : '';

            const chatConnection = new signalR.HubConnectionBuilder()
                .withUrl('/chathub')
                .withAutomaticReconnect()
                .build();

            function getUnreadMap() {
                if (!unreadStorageKey) return {};

                try {
                    return JSON.parse(localStorage.getItem(unreadStorageKey) || '{}');
                } catch {
                    return {};
                }
            }

            function saveUnreadMap(map) {
                if (!unreadStorageKey) return;
                localStorage.setItem(unreadStorageKey, JSON.stringify(map));
            }

            function setRoomUnread(threadId, hasUnread) {
                if (!threadId) return;

                const dot = document.querySelector(`[data-unread-dot-for="${threadId}"]`);
                if (!dot) return;

                dot.classList.toggle('hidden', !hasUnread);
            }

            function syncUnreadUiFromStorage() {
                const unreadMap = getUnreadMap();
                document.querySelectorAll('[data-unread-dot-for]').forEach(dot => {
                    const threadId = dot.getAttribute('data-unread-dot-for') || '';
                    const hasUnread = Boolean(unreadMap[threadId]);
                    dot.classList.toggle('hidden', !hasUnread);
                });
            }

            function updateUnreadState(threadId, hasUnread) {
                if (!threadId) return;

                const unreadMap = getUnreadMap();

                if (hasUnread) {
                    unreadMap[threadId] = true;
                } else {
                    delete unreadMap[threadId];
                }

                saveUnreadMap(unreadMap);
                setRoomUnread(threadId, hasUnread);
            }

            syncUnreadUiFromStorage();

            if (selectedThreadId) {
                updateUnreadState(selectedThreadId, false);
            }

            chatConnection.on('ReceiveMessage', async function () {
                if (selectedThreadId && currentUserId) {
                    try {
                        await chatConnection.invoke('MarkThreadAsRead', Number(selectedThreadId), Number(currentUserId));
                    } catch (err) {
                        console.error('MarkThreadAsRead error:', err);
                    }
                }

                location.reload();
            });

            chatConnection.on('MessageEdited', function () {
                location.reload();
            });

            chatConnection.on('MessageDeleted', function () {
                location.reload();
            });

            chatConnection.on('ThreadUnreadChanged', function (payload) {
                if (!payload) return;

                const threadId = payload.threadId?.toString?.() ?? '';
                const hasUnread = Boolean(payload.hasUnread);

                if (threadId === selectedThreadId) {
                    updateUnreadState(threadId, false);
                    return;
                }

                updateUnreadState(threadId, hasUnread);
            });

            async function startChatConnection() {
                try {
                    await chatConnection.start();
                    console.log('Chat SignalR connected.');

                    if (currentUserGroup) {
                        await chatConnection.invoke('JoinUserGroup', currentUserGroup);
                    }

                    if (selectedThreadId) {
                        await chatConnection.invoke('JoinThread', selectedThreadId);
                        await chatConnection.invoke('MarkThreadAsRead', Number(selectedThreadId), Number(currentUserId));
                        console.log('Joined thread:', selectedThreadId);
                    }
                } catch (err) {
                    console.error('Chat SignalR error:', err);
                    setTimeout(startChatConnection, 3000);
                }
            }

            startChatConnection();
        });
    </script>

}
