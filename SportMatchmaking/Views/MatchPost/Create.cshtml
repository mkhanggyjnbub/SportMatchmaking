@model SportMatchmaking.Models.MatchPostFormVM

@{
    ViewData["Title"] = "Tạo bài đăng";
}

<div class="match-page-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">Tạo kèo mới</h2>
            <p class="text-muted mb-0">Tạo bài đăng tìm người chơi phù hợp và tự động thêm bạn làm chủ kèo.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại feed</a>
    </div>

    <div class="card match-surface-card shadow-sm border-0">
        <div class="card-body p-4 p-lg-5">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <partial name="_MatchPostForm" model="Model" />

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Đăng bài</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"
          crossorigin="" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="~/js/match-post-map-picker.js" asp-append-version="true"></script>
}
