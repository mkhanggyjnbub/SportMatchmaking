@model SportMatchmaking.Models.MatchPostFormVM

@{
    ViewData["Title"] = "Sửa bài đăng";
}

<div class="match-page-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">Sửa bài đăng</h2>
            <p class="text-muted mb-0">Cập nhật thông tin trận đấu, slot và khu vực trước khi bài hoàn thành hoặc bị hủy.</p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">Quay lại chi tiết</a>
    </div>

    <div class="card match-surface-card shadow-sm border-0">
        <div class="card-body p-4 p-lg-5">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="PostId" type="hidden" />
                <input asp-for="IsEdit" type="hidden" />

                <partial name="_MatchPostForm" model="Model" />

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                    <a asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
