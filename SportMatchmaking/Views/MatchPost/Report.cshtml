@model SportMatchmaking.Models.CreatePostReportVM

@{
    ViewData["Title"] = "Report bài đăng";
}

<div class="match-page-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">Report bài đăng</h2>
            <p class="text-muted mb-0">Bài đăng: <strong>@Model.PostTitle</strong></p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">Quay lại chi tiết</a>
    </div>

    <div class="card match-surface-card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Report" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="PostId" type="hidden" />
                <input asp-for="PostTitle" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="ReasonCode" class="form-label">Lý do report</label>
                    <select asp-for="ReasonCode" asp-items="Model.ReasonOptions" class="form-select">
                        <option value="">-- Chọn lý do --</option>
                    </select>
                    <span asp-validation-for="ReasonCode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Details" class="form-label">Chi tiết</label>
                    <textarea asp-for="Details" rows="5" class="form-control" placeholder="Mô tả thêm nội dung bạn muốn admin xem xét..."></textarea>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Gửi report</button>
                    <a asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
