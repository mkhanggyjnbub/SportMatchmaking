@model SportMatchmaking.Models.MatchPostIndexVM

@{
    ViewData["Title"] = "Kèo của tôi";
}

<div class="match-page-shell">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">Kèo của tôi</h2>
            <p class="text-muted mb-0">Quản lý bài đăng đã tạo, duyệt request và chốt trạng thái trận.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Tạo bài đăng mới</a>
    </div>

    <form method="get" asp-action="MyPosts" class="match-filter-panel card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Keyword" class="form-label">Từ khóa</label>
                    <input asp-for="Keyword" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Môn thể thao</label>
                    <select asp-for="SportId" asp-items="Model.SportOptions" class="form-select">
                        <option value="">Tất cả</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái</label>
                    <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                        <option value="">Tất cả</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="IsUrgent" class="form-label">Urgent</label>
                    <select asp-for="IsUrgent" class="form-select">
                        <option value="">Tất cả</option>
                        @if (Model.IsUrgent == true)
                        {
                            <option value="true" selected>Có</option>
                        }
                        else
                        {
                            <option value="true">Có</option>
                        }
                        @if (Model.IsUrgent == false)
                        {
                            <option value="false" selected>Không</option>
                        }
                        else
                        {
                            <option value="false">Không</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary">Lọc</button>
                    <a asp-action="MyPosts" class="btn btn-outline-secondary">Xóa lọc</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Posts == null || !Model.Posts.Any())
    {
        <div class="alert alert-info">Bạn chưa có bài đăng nào khớp bộ lọc.</div>
    }
    else
    {
        <div class="card match-surface-card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3 py-3">Bài đăng</th>
                            <th class="px-3 py-3">Thời gian</th>
                            <th class="px-3 py-3">Slot</th>
                            <th class="px-3 py-3">Trạng thái</th>
                            <th class="px-3 py-3">Urgent</th>
                            <th class="px-3 py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in Model.Posts)
                        {
                            <tr>
                                <td class="px-3 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrWhiteSpace(post.SportImageUrl))
                                        {
                                            <img src="@post.SportImageUrl" alt="@post.SportName" class="match-sport-thumb" />
                                        }
                                        else
                                        {
                                            <div class="match-sport-thumb match-sport-card-placeholder">
                                                <span>@post.SportName</span>
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-semibold">@post.Title</div>
                                            @{
                                                var myPostArea = string.Join(", ", new[] { post.District, post.City }
                                                    .Where(x => !string.IsNullOrWhiteSpace(x)));
                                            }
                                            <div class="text-muted small">
                                                @post.SportName@(string.IsNullOrWhiteSpace(myPostArea) ? "" : $" · {myPostArea}")
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-3 py-3">@post.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-3 py-3">@post.SlotsRemaining / @post.SlotsNeeded</td>
                                <td class="px-3 py-3">
                                    <span class="badge text-bg-secondary">@post.StatusText</span>
                                </td>
                                <td class="px-3 py-3">@(post.IsUrgent ? "Có" : "Không")</td>
                                <td class="px-3 py-3">
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-action="Details" asp-route-id="@post.PostId" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                        <a asp-controller="JoinRequest" asp-action="PostRequests" asp-route-postId="@post.PostId" class="btn btn-sm btn-outline-dark">Requests</a>
                                        @if (post.CanEdit)
                                        {
                                            <a asp-action="Edit" asp-route-id="@post.PostId" class="btn btn-sm btn-outline-secondary">Sửa</a>
                                        }

                                        @if (post.CanConfirm)
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@post.PostId" />
                                                <input type="hidden" name="status" value="@((byte)BusinessObjects.PostStatus.Confirmed)" />
                                                <input type="hidden" name="returnAction" value="MyPosts" />
                                                <button type="submit" class="btn btn-sm btn-success">Chốt trận</button>
                                            </form>
                                        }

                                        @if (post.CanComplete)
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@post.PostId" />
                                                <input type="hidden" name="status" value="@((byte)BusinessObjects.PostStatus.Completed)" />
                                                <input type="hidden" name="returnAction" value="MyPosts" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">Hoàn thành</button>
                                            </form>
                                        }

                                        @if (post.CanCancel)
                                        {
                                            <form asp-action="Cancel" method="post" onsubmit="return confirm('Bạn có chắc muốn hủy bài đăng này không?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@post.PostId" />
                                                <input type="hidden" name="returnAction" value="MyPosts" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Hủy</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
