@model BusinessObjects.Sport

@{
    ViewData["Title"] = "Chi tiết môn thể thao";
}

<h2 class="admin-page-title mb-1">Chi tiết môn thể thao</h2>
<p class="admin-page-subtitle mb-4">Thông tin đầy đủ của môn thể thao trong hệ thống.</p>

<div class="card admin-card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Mã môn thể thao</dt>
            <dd class="col-sm-9 fw-semibold">@Model.SportId</dd>

            <dt class="col-sm-3">Tên môn thể thao</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Số người tối thiểu mỗi đội</dt>
            <dd class="col-sm-9">@Model.TeamMin</dd>

            <dt class="col-sm-3">Số người tối đa mỗi đội</dt>
            <dd class="col-sm-9">@Model.TeamMax</dd>

            <dt class="col-sm-3">Mã hình ảnh</dt>
            <dd class="col-sm-9">@Model.ImageId</dd>

            <dt class="col-sm-3">Đường dẫn hình ảnh</dt>
            <dd class="col-sm-9 text-break">@(Model.Image?.ImageUrl ?? "")</dd>

            <dt class="col-sm-3">Ngày tạo</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2 flex-wrap">
    <a asp-action="Edit" asp-route-id="@Model.SportId" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>