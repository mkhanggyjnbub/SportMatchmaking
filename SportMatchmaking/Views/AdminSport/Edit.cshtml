@model BusinessObjects.Sport

@{
    ViewData["Title"] = "Sửa môn thể thao";
    var images = ViewBag.SportImages as List<BusinessObjects.SportImage>;
}

<h2 class="admin-page-title mb-1">Sửa môn thể thao</h2>
<p class="admin-page-subtitle mb-4">Cập nhật thông tin môn thể thao.</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card admin-card">
    <div class="card-body">
        <form asp-action="Edit" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <input asp-for="SportId" type="hidden" />

            <div class="col-md-6">
                <label class="form-label">Tên môn thể thao</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Team Min</label>
                <input asp-for="TeamMin" class="form-control" type="number" required />
            </div>

            <div class="col-md-3">
                <label class="form-label">Team Max</label>
                <input asp-for="TeamMax" class="form-control" type="number" required />
            </div>

            <div class="col-md-12">
                <label class="form-label">Ảnh</label>
                <select asp-for="ImageId" class="form-select">
                    <option value="">-- Chọn ảnh --</option>
                    @if (images != null)
                    {
                        foreach (var img in images)
                        {
                            if (Model.ImageId == img.ImageId)
                            {
                                <option value="@img.ImageId" selected>@img.ImageId - @img.ImageUrl</option>
                            }
                            else
                            {
                                <option value="@img.ImageId">@img.ImageId - @img.ImageUrl</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Cập nhật</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>