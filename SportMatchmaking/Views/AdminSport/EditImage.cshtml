@model SportMatchmaking.Models.SportImageUploadVM

@{
    ViewData["Title"] = "Upload ảnh môn thể thao";
}

<h2 class="admin-page-title mb-1">Upload ảnh môn thể thao</h2>
<p class="admin-page-subtitle mb-4">Cập nhật file ảnh trong thư viện.</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card admin-card">
    <div class="card-body">
        <form asp-action="EditImage" method="post" enctype="multipart/form-data" class="row g-3">
            @Html.AntiForgeryToken()

            <input asp-for="ImageId" type="hidden" />

            @if (!string.IsNullOrWhiteSpace(Model.CurrentImageUrl))
            {
                <div class="col-12">
                    <label class="form-label">Ảnh hiện tại</label>
                    <div>
                        <img src="@Model.CurrentImageUrl" alt="Sport image" style="max-width:220px; max-height:220px;" class="img-thumbnail" />
                    </div>
                </div>
            }

            <div class="col-12">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
                <div class="form-text">Để trống nếu muốn giữ ảnh hiện tại. Chấp nhận .jpg, .jpeg, .png, .webp. Tối đa 5MB.</div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Upload ảnh mới</button>
                <a asp-action="Images" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>
