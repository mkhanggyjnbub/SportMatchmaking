@model BusinessObjects.SportImage

@{
    ViewData["Title"] = "Thêm ảnh môn thể thao";
}

<h2 class="admin-page-title mb-1">Thêm ảnh môn thể thao</h2>
<p class="admin-page-subtitle mb-4">Thêm URL ảnh mới cho thư viện môn thể thao.</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card admin-card">
    <div class="card-body">
        <form asp-action="CreateImage" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-12">
                <label class="form-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" />
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Images" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>