@model List<BusinessObjects.SportImage>

@{
    ViewData["Title"] = "Quản lý ảnh môn thể thao";
    var currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 10;
}

<h2 class="admin-page-title mb-1">Quản lý ảnh môn thể thao</h2>
<p class="admin-page-subtitle mb-4">Danh sách ảnh dùng cho các môn thể thao.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="admin-filter d-flex gap-2 flex-wrap mb-4">
    <a asp-action="CreateImage" class="btn btn-success">Upload ảnh</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách môn thể thao</a>
</div>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 admin-table admin-table-mobile-cards">
            <thead>
                <tr>
                    <th>ImageId</th>
                    <th>Xem trước</th>
                    <th>ImageUrl</th>
                    <th style="width:180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var img in Model)
                    {
                        <tr>
                            <td data-label="ImageId">@img.ImageId</td>
                            <td data-label="Xem trước">
                                @if (!string.IsNullOrWhiteSpace(img.ImageUrl))
                                {
                                    <img src="@img.ImageUrl" alt="Sport image @img.ImageId" style="width:72px; height:72px; object-fit:cover;" class="rounded border" />
                                }
                            </td>
                            <td data-label="ImageUrl" class="text-break">@img.ImageUrl</td>
                            <td data-label="Thao tác" class="admin-actions">
                                <a asp-action="EditImage" asp-route-id="@img.ImageId" class="btn btn-sm btn-warning">Upload ảnh mới</a>

                                <form asp-action="DeleteImage" asp-route-id="@img.ImageId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Bạn có chắc muốn xóa ảnh này?')">
                                        Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4">Không có dữ liệu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination mb-0">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Images"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-pageSize="@pageSize">Trước</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Images"
                       asp-route-page="@i"
                       asp-route-pageSize="@pageSize">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Images"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-pageSize="@pageSize">Sau</a>
            </li>
        </ul>
    </nav>
}
