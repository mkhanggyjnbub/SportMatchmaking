@model List<SportMatchmaking.Models.PostJoinRequestItemVM>

@{
    ViewData["Title"] = "Danh sách request của bài đăng";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Danh sách request của bài đăng</h2>
            <p class="text-muted mb-0">PostId: @ViewBag.PostId</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            Quay lại
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Bài đăng này hiện chưa có request nào.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-3 py-3">Người gửi</th>
                                <th class="px-3 py-3">PartySize</th>
                                <th class="px-3 py-3">Lời nhắn</th>
                                <th class="px-3 py-3">Thời điểm gửi</th>
                                <th class="px-3 py-3">Trạng thái</th>
                                <th class="px-3 py-3">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-3 py-3">
                                        <div class="fw-semibold">@item.RequesterName</div>
                                        <div class="text-muted small">UserId: @item.RequesterUserId</div>
                                    </td>
                                    <td class="px-3 py-3">@item.PartySize</td>
                                    <td class="px-3 py-3">
                                        @(string.IsNullOrWhiteSpace(item.Message) ? "(Không có lời nhắn)" : item.Message)
                                    </td>
                                    <td class="px-3 py-3">
                                        @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="px-3 py-3">
                                        @switch (item.Status)
                                        {
                                            case 1:
                                                @:Pending
                                                break;
                                            case 2:
                                                @:Accepted
                                                break;
                                            case 3:
                                                @:Rejected
                                                break;
                                            case 4:
                                                @:Cancelled
                                                break;
                                            default:
                                                @:Unknown
                                                break;
                                        }
                                    </td>
                                    <td class="px-3 py-3">
                                        @if (item.CanApprove)
                                        {
                                            <div class="d-flex gap-2">
                                                <form asp-controller="JoinRequest"
                                                      asp-action="Accept"
                                                      method="post"
                                                      onsubmit="return confirm('Bạn có chắc muốn chấp nhận request này không?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@item.RequestId" />
                                                    <input type="hidden" name="postId" value="@ViewBag.PostId" />
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        Accept
                                                    </button>
                                                </form>

                                                <form asp-controller="JoinRequest"
                                                      asp-action="Reject"
                                                      method="post"
                                                      onsubmit="return confirm('Bạn có chắc muốn từ chối request này không?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@item.RequestId" />
                                                    <input type="hidden" name="postId" value="@ViewBag.PostId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        Reject
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>