@model Dictionary<string, int>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
    <div>
        <h2 class="admin-page-title mb-1">Admin Dashboard</h2>
        <p class="admin-page-subtitle mb-0">Tổng quan nhanh hệ thống quản trị.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card admin-stat-card" style="background: linear-gradient(135deg, #4f46e5, #6366f1);">
            <div class="card-body">
                <div class="small">Tổng người dùng</div>
                <div class="admin-stat-number">@Model.GetValueOrDefault("TotalUsers")</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-stat-card" style="background: linear-gradient(135deg, #dc2626, #ef4444);">
            <div class="card-body">
                <div class="small">Người dùng bị khóa</div>
                <div class="admin-stat-number">@Model.GetValueOrDefault("BannedUsers")</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-stat-card" style="background: linear-gradient(135deg, #0ea5e9, #38bdf8);">
            <div class="card-body">
                <div class="small">Tổng bài đăng</div>
                <div class="admin-stat-number">@Model.GetValueOrDefault("TotalPosts")</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-stat-card" style="background: linear-gradient(135deg, #16a34a, #22c55e);">
            <div class="card-body">
                <div class="small">Bài đăng hoàn thành</div>
                <div class="admin-stat-number">@Model.GetValueOrDefault("CompletedPosts")</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-stat-card" style="background: linear-gradient(135deg, #7c3aed, #a855f7);">
            <div class="card-body">
                <div class="small">Tổng yêu cầu tham gia</div>
                <div class="admin-stat-number">@Model.GetValueOrDefault("TotalJoinRequests")</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-stat-card" style="background: linear-gradient(135deg, #d97706, #f59e0b);">
            <div class="card-body">
                <div class="small">Report đang mở</div>
                <div class="admin-stat-number">@Model.GetValueOrDefault("OpenReports")</div>
            </div>
        </div>
    </div>
</div>

<div class="card admin-card mt-4">
    <div class="card-body">
        <h5 class="mb-3">Điều hướng nhanh</h5>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="AdminUser" asp-action="Index" class="btn btn-primary">Quản lý User</a>
            <a asp-controller="AdminPost" asp-action="Index" class="btn btn-success">Quản lý Bài đăng</a>
            <a asp-controller="AdminSport" asp-action="Index" class="btn btn-info text-white">Quản lý Môn thể thao</a>
            <a asp-controller="AdminReport" asp-action="Index" class="btn btn-warning">Quản lý Report</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Quay về Home</a>
        </div>
    </div>
</div>