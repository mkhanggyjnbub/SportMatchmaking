@model List<SportMatchmaking.Models.NotificationItemVM>

<div class="list-group list-group-flush">
    @if (Model == null || !Model.Any())
    {
        <div class="list-group-item text-center text-muted small py-3">
            Chưa có thông báo nào.
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            var isUnreadClass = item.IsRead ? "" : "fw-bold";
            <a class="list-group-item list-group-item-action border-0 border-bottom small @isUnreadClass" href="javascript:void(0)">
                <div class="d-flex justify-content-between">
                    <span>@item.Title</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(item.Body))
                {
                    <div class="text-muted mt-1" style="font-size: 0.8rem;">
                        @item.Body
                    </div>
                }
                <div class="text-muted mt-1" style="font-size: 0.7rem;">
                    @item.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
                </div>
            </a>
        }
    }
</div>
