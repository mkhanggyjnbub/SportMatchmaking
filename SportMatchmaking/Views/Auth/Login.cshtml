@model SportMatchmaking.Models.LoginVM

@{
    ViewData["Title"] = "Login";
}

<div class="register-page">
    <div class="register-card">
        <div class="register-header">
            <h2>Login</h2>
            <p>Welcome back to SportMatchmaking</p>
        </div>

        <div class="register-body">
            @if (ViewBag.LoginSuccess != null)
            {
                <div class="alert alert-success">@ViewBag.LoginSuccess</div>
            }

            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-register">Login</button>
                </div>

                <div class="register-footer">
                    Don't have an account?
                    <a asp-action="Register" asp-controller="Auth">Register</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @* Tự động chuyển hướng sau khi đăng nhập thành công *@
    @if (ViewBag.RedirectUrl != null)
    {
        <script>
            setTimeout(function () {
                window.location.href = '@ViewBag.RedirectUrl';
            }, 0); // đợi 1.5s để user kịp thấy thông báo
        </script>
    }
}