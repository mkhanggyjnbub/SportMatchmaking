@model SportMatchmaking.Models.ResetPasswordVM

@{
    ViewData["Title"] = "New password";
}

<div class="register-page">
    <div class="register-card">
        <div class="register-header">
            <h2>Set new password</h2>
            <p>Choose a new password for your account</p>
        </div>

        <div class="register-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="ResetToken" />

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="New password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-register">Update password</button>
                </div>

                <div class="register-footer">
                    <a asp-action="Login" asp-controller="Auth">Login</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
