@model List<BusinessObjects.AppUser>

@{
    ViewData["Title"] = "Quản lý User";
    var roles = ViewBag.Roles as List<BusinessObjects.Role>;
}

<h2 class="admin-page-title mb-1">Quản lý User</h2>
<p class="admin-page-subtitle mb-4">Theo dõi người dùng, role và trạng thái khóa tài khoản.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" asp-action="Index" class="admin-filter row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Từ khóa</label>
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control"
            placeholder="Email, username, display name..." />
    </div>

    <div class="col-md-3">
        <label class="form-label">Role</label>
        <select name="roleId" class="form-select">
            <option value="">-- Tất cả --</option>
            @if (roles != null)
            {
                foreach (var role in roles)
                {
                    if (ViewBag.RoleId != null && (int)ViewBag.RoleId == role.RoleId)
                    {
                        <option value="@role.RoleId" selected>@role.Name</option>
                    }
                    else
                    {
                        <option value="@role.RoleId">@role.Name</option>
                    }
                }
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Trạng thái khóa</label>
        <select name="isBanned" class="form-select">
            <option value="">-- Tất cả --</option>
            @if (ViewBag.IsBanned != null && (bool)ViewBag.IsBanned == true)
            {
                <option value="true" selected>Đã khóa</option>
                <option value="false">Đang hoạt động</option>
            }
            else if (ViewBag.IsBanned != null && (bool)ViewBag.IsBanned == false)
            {
                <option value="true">Đã khóa</option>
                <option value="false" selected>Đang hoạt động</option>
            }
            else
            {
                <option value="true">Đã khóa</option>
                <option value="false">Đang hoạt động</option>
            }
        </select>
    </div>

    <div class="col-md-2 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary w-100">Lọc</button>
    </div>
</form>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>UserName</th>
                    <th>Email</th>
                    <th>Display Name</th>
                    <th>City</th>
                    <th>RoleId</th>
                    <th>IsBanned</th>
                    <th>Created At</th>
                    <th style="width:220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.DisplayName</td>
                            <td>@user.City</td>
                            <td>@user.RoleId</td>
                            <td>
                                @if (user.IsBanned)
                                {
                                    <span class="badge bg-danger admin-badge">Đã khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success admin-badge">Hoạt động</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="admin-actions">
                                <a asp-action="Details" asp-route-id="@user.UserId" class="btn btn-sm btn-info text-white">
                                    Chi tiết
                                </a>
                                <a asp-action="EditRole" asp-route-id="@user.UserId" class="btn btn-sm btn-warning">Đổi
                                    Role</a>

                                <form asp-action="ToggleBan" asp-route-id="@user.UserId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(user.IsBanned ? "btn-success" : "btn-danger")"
                                        onclick="return confirm('Bạn có chắc muốn thay đổi trạng thái khóa của user này?')">
                                        @(user.IsBanned ? "Mở khóa" : "Khóa")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-4">Không có dữ liệu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
