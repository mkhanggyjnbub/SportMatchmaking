@model BusinessObjects.AppUser

@{
    ViewData["Title"] = "Đổi Role User";
    var roles = ViewBag.Roles as List<BusinessObjects.Role>;
}

<h2 class="admin-page-title mb-1">Đổi Role User</h2>
<p class="admin-page-subtitle mb-4">Cập nhật quyền truy cập cho tài khoản.</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card admin-card">
    <div class="card-body">
        <form asp-action="EditRole" asp-route-id="@Model.UserId" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-md-6">
                <label class="form-label">UserName</label>
                <input class="form-control" value="@Model.UserName" readonly />
            </div>

            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input class="form-control" value="@Model.Email" readonly />
            </div>

            <div class="col-md-6">
                <label class="form-label">Role hiện tại</label>
                <input class="form-control" value="@Model.RoleId" readonly />
            </div>

            <div class="col-md-6">
                <label class="form-label">Role mới</label>
                <select name="roleId" class="form-select" required>
                    <option value="">-- Chọn role --</option>
                    @if (roles != null)
                    {
                        foreach (var role in roles)
                        {
                            if (role.RoleId == Model.RoleId)
                            {
                                <option value="@role.RoleId" selected>@role.Name</option>
                            }
                            else
                            {
                                <option value="@role.RoleId">@role.Name</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>