@model BusinessObjects.AppUser

@{
    ViewData["Title"] = "Chi tiết User";
}

<h2 class="admin-page-title mb-1">Chi tiết User</h2>
<p class="admin-page-subtitle mb-4">Thông tin đầy đủ của tài khoản người dùng.</p>

<div class="card admin-card">
    <div class="card-body">
        <dl class="row mb-0 admin-detail-list">
            <dt class="col-sm-3">User ID</dt>
            <dd class="col-sm-9 fw-semibold">@Model.UserId</dd>

            <dt class="col-sm-3">UserName</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Display Name</dt>
            <dd class="col-sm-9">@Model.DisplayName</dd>

            <dt class="col-sm-3">Phone Number</dt>
            <dd class="col-sm-9">@Model.PhoneNumber</dd>

            <dt class="col-sm-3">Avatar</dt>
            <dd class="col-sm-9 text-break">@Model.AvatarUrl</dd>

            <dt class="col-sm-3">Bio</dt>
            <dd class="col-sm-9">@Model.Bio</dd>

            <dt class="col-sm-3">City</dt>
            <dd class="col-sm-9">@Model.City</dd>

            <dt class="col-sm-3">District</dt>
            <dd class="col-sm-9">@Model.District</dd>

            <dt class="col-sm-3">Skill Level</dt>
            <dd class="col-sm-9">@Model.SkillLevel</dd>

            <dt class="col-sm-3">Role ID</dt>
            <dd class="col-sm-9">@Model.RoleId</dd>

            <dt class="col-sm-3">Is Banned</dt>
            <dd class="col-sm-9">
                @if (Model.IsBanned)
                {
                    <span class="badge bg-danger admin-badge">Có</span>
                }
                else
                {
                    <span class="badge bg-success admin-badge">Không</span>
                }
            </dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Updated At</dt>
            <dd class="col-sm-9">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>